PORT=3001
CORS_ORIGINS=http://localhost:3000

# Supabase (same project as mobile/admin)
SUPABASE_URL=https://your-project.supabase.co
# JWT secret used to verify Supabase-issued user access tokens (HS256).
# Dashboard: Project Settings → API → JWT Secret (legacy) — NOT the anon key, NOT the service_role key string by itself.
SUPABASE_JWT_SECRET=get_from_supabase_dashboard_settings_api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Postgres — pooled URL for runtime (PgBouncer); direct for migrations
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Cloudflare R2 (S3-compatible) — used for order photo uploads.
# Setup steps:
#   1. Cloudflare dashboard → R2 → Create bucket (e.g. `order-photos`).
#   2. Manage R2 API Tokens → Create token with Object Read & Write
#      scoped to the bucket. Copy the Access Key ID + Secret Access Key.
#   3. R2_ACCOUNT_ID is shown on the R2 dashboard's right-hand sidebar.
#   4. Bucket → Settings → CORS Policy:
#        [{ "AllowedOrigins": ["*"], "AllowedMethods": ["PUT","GET"],
#           "AllowedHeaders": ["content-type"], "MaxAgeSeconds": 3000 }]
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=order-photos
