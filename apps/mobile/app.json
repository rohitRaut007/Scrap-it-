{
  "expo": {
    "name": "Scrap-it",
    "slug": "Scrap-it",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "scrapit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Scrap-it uses your location to show nearby pickups and route tracking.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Scrap-it uses your location during active pickup tracking.",
        "NSPhotoLibraryUsageDescription": "Scrap-it needs access to your photo library so you can attach reference images for pickup estimation."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.scrapit.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Scrap-it needs access to your photo library so you can attach reference images for pickup estimation."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    }
  }
}
